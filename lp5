#include<iostream>
#include<climits>
#include<vector>
#include<omp.h>
#include<bits/stdc++.h>
#include<queue>
#include<stack>
using namespace std;
void bfs(int start, vector<vector<int>>&p, vector<bool>&visited){
    
    queue<int>q;
    q.push(start);
    visited[start]=true;
    while(q.size()!=0){
        int d=q.front();
        #pragma omp parallel for
        for(int i=0;i<p[d].size();i++){
            #pragma omp critical
            {
                 if(visited[p[d][i]]==false){
                    visited[p[d][i]]=true;
                    q.push(p[d][i]);
                }
            }
           
        }
        cout<<d<<endl;
        q.pop();
    }
}
void dfs(int start, vector<vector<int>>&p, vector<bool>&visited){
    stack<int>s;
    s.push(start);
    visited[start]=true;
    while(s.size()!=0){
        int d=s.top();
        s.pop();
        cout<<d<<" ";
        #pragma omp parallel for
        for(int i=p[d].size()-1;i>=0;i--){
            #pragma omp critical
            {
                if(visited[p[d][i]]==false){
                    visited[p[d][i]]=true;
                    s.push(p[d][i]);
                }
            }
            
        }
    }
}
int main(){
    vector<vector<int>>p(7);
    p[1]={2,3};
    p[2]={1,4,5};
    p[3]={1,6};
    p[4]={2};
    p[5]={2};
    p[6]={3};
    vector<bool>visited(p.size()+1,false);
    int start=1;
    // bfs(start,p,visited);
    dfs(start,p,visited);
    return 0;
}


