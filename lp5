#include<iostream>
#include<vector>
#include<omp.h>
#include<queue>
#include<stack>
#include<algorithm>
using namespace std;
void bubble(vector<int>&p){
    for(int i=0;i<p.size();i++){
        #pragma omp parallel for
        for(int j=i%2;j<p.size()-1;j+=2){
            if(p[j]>p[j+1]){
                swap(p[j],p[j+1]);
            }
        }
    }
}
void merge(vector<int>&p,int l, int mid, int h){
    vector<int>temp;
    int a=l;
    int b=mid+1;
    while(a<=mid && b<=h){
        if(p[a]<p[b]){
            temp.push_back(p[a]);
            a++;
        }
        else if(p[b]<=p[a]){
            temp.push_back(p[b]);
            b++;
        }
    }
    while(a<=mid){
        temp.push_back(p[a]);
        a++;
    }
    while(b<=h){
        temp.push_back(p[b]);
        b++;
    }
    for(int k=0;k<temp.size();k++){
        p[l+k]=temp[k];
    }
}
void mergesort(vector<int>&p,int l, int h){
    if(l<h){
        int mid=(l+h)/2;
        #pragma omp parallel sections
        {
            #pragma omp section
            {
                mergesort(p,l,mid);
            }
            #pragma omp section
            {
                mergesort(p,mid+1,h);
            }
        }
        
        
        merge(p,l,mid,h);
    }
}
int main(){
    vector<int>p={6,1,4,2};
    // bubble(p);
    // for(auto i:p){
    //     cout<<i<<" ";
    // }
    int l=0;
    int h=p.size()-1;
    cout<<endl;
    mergesort(p,l,h);
    for(auto i:p){
        cout<<i<<" ";
    }
    return 0;
}
